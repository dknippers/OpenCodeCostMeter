<Window x:Class="TokenTrackerWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TokenTrackerWidget.Converters"
        xmlns:vm="clr-namespace:TokenTrackerWidget.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="OpenCode Token Tracker"
        SizeToContent="WidthAndHeight"
        MinWidth="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:WidgetViewModel}">
    <Window.Resources>
        <SolidColorBrush x:Key="MicaBg" Color="#20201F"/>
        <SolidColorBrush x:Key="MicaStroke" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="LayerStroke" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="OnSurface" Color="#E5E2E1"/>
        <SolidColorBrush x:Key="OnSurfaceVariant" Color="#C0C7D4"/>
        <SolidColorBrush x:Key="Primary" Color="#A3C9FF"/>
        <SolidColorBrush x:Key="Secondary" Color="#61DBB4"/>
        <SolidColorBrush x:Key="SurfaceLowest" Color="#0E0E0E"/>
        <SolidColorBrush x:Key="RowHover" Color="#2A2A2A"/>
        <conv:BoolToBrushConverter x:Key="LiveBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI, Inter</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Mono, Cascadia Code, Consolas</FontFamily>
        <Style TargetType="Border">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariant}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{StaticResource MicaBg}"
            BorderBrush="{StaticResource MicaStroke}"
            BorderThickness="1"
            MouseLeftButtonDown="OnCardMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top App Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceLowest}"
                    BorderBrush="{StaticResource LayerStroke}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="OpenCode" FontFamily="{StaticResource UiFont}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource OnSurface}" VerticalAlignment="Center"/>
                        <Ellipse Width="6" Height="6" Margin="10,0,0,0"
                                 Fill="{Binding IsLive, Converter={StaticResource LiveBrush}}"
                                 VerticalAlignment="Center"
                                 ToolTip="{Binding ActiveModelText}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource IconBtn}" Click="OnSettingsClicked" ToolTip="Settings" Margin="0,0,8,0">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94 0 .31.04.64.09.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.03-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource IconBtn}" Click="OnCloseClicked" ToolTip="Quit">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <StackPanel Grid.Row="1" Margin="16,14">

                <!-- Primary Spend Card -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding TodayCostText}" FontFamily="{StaticResource UiFont}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource OnSurface}"/>
                    <StackPanel Orientation="Horizontal" Margin="8,0,0,6" VerticalAlignment="Center"
                                Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}">
                        <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,3,0"
                              Data="M10 4l5 5h-3v6h-4V9H5z"
                              Fill="{StaticResource Secondary}"/>
                        <TextBlock Text="{Binding TodayCostDeltaText}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource Secondary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Separator -->
                <Border Height="1" Background="{StaticResource LayerStroke}" Margin="0,12"/>

                <!-- Breakdown List -->
                <ItemsControl ItemsSource="{Binding ModelRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ModelRowViewModel}">
                            <Border CornerRadius="8" Padding="8,6" Margin="0,1"
                                    Background="Transparent"
                                    ToolTip="{Binding CallsText}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource RowHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Header}" FontFamily="{StaticResource UiFont}" FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource OnSurface}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CostText}" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Medium"
                                               Foreground="{StaticResource OnSurfaceVariant}" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Retry indicator -->
                <StackPanel Margin="0,8,0,0" Orientation="Horizontal"
                            Visibility="{Binding IsRetrying, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding LastErrorText}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                               Foreground="#E0B341"/>
                </StackPanel>
            </StackPanel>

            </Grid>
    </Border>
</Window>