<Window x:Class="TokenTrackerWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TokenTrackerWidget.Converters"
        xmlns:vm="clr-namespace:TokenTrackerWidget.ViewModels"
        xmlns:m="clr-namespace:TokenTrackerWidget.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="OpenCode Token Tracker"
        Height="240" Width="260"
        MinHeight="160" MinWidth="240"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=vm:WidgetViewModel}">
    <Window.Resources>
        <conv:BigNumberConverter x:Key="BigNum"/>
        <conv:CurrencyConverter x:Key="Cur"/>
        <conv:BoolToBrushConverter x:Key="LiveBrush"/>
        <conv:DisplayModeToVisibilityConverter x:Key="ModeVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="CardBg" Color="#1E1E1E" Opacity="0.92"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="TextHi" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TextLo" Color="#9A9A9A"/>
        <SolidColorBrush x:Key="Accent" Color="#4CE38B"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#E0B341"/>
        <Style x:Key="RowKey" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLo}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RowVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border x:Name="CardRoot"
            CornerRadius="8"
            Background="{StaticResource CardBg}"
            BorderBrush="{StaticResource CardBorder}"
            BorderThickness="1"
            Padding="10,8"
            MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="OpenCode · today" FontWeight="SemiBold"
                           Foreground="{StaticResource TextHi}" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="6" Height="6" Margin="0,0,4,0"
                             Fill="{Binding IsLive, Converter={StaticResource LiveBrush}}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveModelText}" Foreground="{StaticResource TextLo}"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,2,0"/>
                    <Button Content="⚙" Width="18" Height="18" Margin="4,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextLo}" FontSize="12"
                            Click="OnMenuClicked" Cursor="Arrow"/>
                    <Button Content="✕" Width="18" Height="18" Margin="2,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextLo}" FontSize="11"
                            Click="OnCloseClicked" Cursor="Arrow"/>
                </StackPanel>
            </Grid>

            <!-- Session label -->
            <TextBlock Grid.Row="1" Margin="0,0,0,6"
                       Text="{Binding ActiveSessionLine}"
                       Foreground="{StaticResource TextLo}" FontSize="10" TextTrimming="CharacterEllipsis"/>

            <Separator Grid.Row="2" Background="{StaticResource CardBorder}" Margin="0,0,0,6"/>

            <!-- Tokens mode block -->
            <StackPanel Grid.Row="3" Visibility="{Binding DisplayMode, Converter={StaticResource ModeVis}, ConverterParameter=Tokens}">
                <Grid Margin="0,1">
                    <TextBlock Text="input" Style="{StaticResource RowKey}"/>
                    <TextBlock Text="{Binding TodayInputText}" Style="{StaticResource RowVal}"/>
                </Grid>
                <Grid Margin="0,1">
                    <TextBlock Text="output" Style="{StaticResource RowKey}"/>
                    <TextBlock Text="{Binding TodayOutputText}" Style="{StaticResource RowVal}"/>
                </Grid>
                <Grid Margin="0,1">
                    <TextBlock Text="reasoning" Style="{StaticResource RowKey}"/>
                    <TextBlock Text="{Binding TodayReasoningText}" Style="{StaticResource RowVal}"/>
                </Grid>
                <Grid Margin="0,1">
                    <TextBlock Text="cache ⟲" Style="{StaticResource RowKey}"/>
                    <TextBlock Text="{Binding TodayCacheReadText}" Style="{StaticResource RowVal}"/>
                </Grid>
                <Grid Margin="0,1">
                    <TextBlock Text="cache ✎" Style="{StaticResource RowKey}"/>
                    <TextBlock Text="{Binding TodayCacheWriteText}" Style="{StaticResource RowVal}"/>
                </Grid>
            </StackPanel>

            <!-- Cost mode block -->
            <StackPanel Grid.Row="4" Visibility="{Binding DisplayMode, Converter={StaticResource ModeVis}, ConverterParameter=Cost}">
                <Grid Margin="0,2,0,4">
                    <TextBlock Text="cost" Style="{StaticResource RowKey}"/>
                    <TextBlock Text="{Binding TodayCostText}" FontWeight="SemiBold" Foreground="{StaticResource Accent}"
                               FontSize="22" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>
                <TextBlock Text="{Binding TodayCostDeltaText}" Foreground="{StaticResource Accent}" FontSize="10"
                           HorizontalAlignment="Right" Margin="0,0,0,4"/>
            </StackPanel>

            <!-- Per-model list -->
            <ItemsControl Grid.Row="5" ItemsSource="{Binding ModelBreakdowns}" Margin="0,6,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:ModelBreakdown}">
                        <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Header}" FontSize="10"
                                       Foreground="{StaticResource TextLo}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{Binding Calls, StringFormat=\{0\}x}" FontSize="10"
                                       Foreground="{StaticResource TextLo}" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Cost, Converter={StaticResource Cur}}"
                                       FontSize="10" Foreground="{StaticResource TextHi}" Margin="8,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer -->
            <Grid Grid.Row="6" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding CallsText}" FontSize="10"
                           Foreground="{StaticResource TextLo}"/>
                <TextBlock Grid.Column="1" Text="{Binding LastErrorText}" FontSize="10"
                           Foreground="{StaticResource WarnBrush}"
                           Visibility="{Binding IsRetrying, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
    </Border>
</Window>